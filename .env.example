# ─────────────────────────────────────────────────────────
#  Nova — Environment Variables
#  Copy to .env and fill in all values before first run.
#  Never commit .env to version control.
#
#  Generate secrets with:  openssl rand -hex 32
# ─────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_DB=nova
POSTGRES_USER=nova
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# Redis
REDIS_PASSWORD=CHANGE_ME_redis_password

# App secrets — generate each with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_32_char_minimum_secret_key
JWT_SECRET=CHANGE_ME_jwt_secret_256bit_minimum
CELERY_HMAC_SECRET=CHANGE_ME_celery_hmac_secret

# Metasploit Pro RPC (leave blank if not using)
METASPLOIT_RPC_HOST=
METASPLOIT_RPC_PORT=55553
METASPLOIT_RPC_PASSWORD=

# Titanux integration (optional — for export push)
TITANUX_URL=
TITANUX_API_KEY=

# Deployment
DOMAIN=nova.yourdomain.com
CERTBOT_EMAIL=your@email.com
ENVIRONMENT=production
FRONTEND_BUILD_TARGET=production
